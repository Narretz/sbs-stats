{
  "rules": [
    {
      "allowed": {
        "origins": [
          "https://narretz.github.io",
          "http://localhost:5173"
        ],
        "methods": ["GET", "HEAD"],
        "headers": ["*"]
      },
      "exposeHeaders": [
        "Content-Length",
        "Content-Range",
        "ETag",
        "Accept-Ranges"
      ],
      "maxAgeSeconds": 3600
    }
  ]
}
